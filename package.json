{
  "name": "chess-backend",
  "version": "1.0.0",
  "description": "Production backend for premium Chess Web App (Supabase + TypeScript + chess.js)",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "migrate": "bash scripts/run_migrations.sh"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "chess.js": "^1.0.0-beta.8",
    "express": "^4.19.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "zod": "^3.23.8",
    "dotenv": "^16.4.5",
    "uuid": "^9.0.1",
    "express-rate-limit": "^7.4.0"
  },
  "devDependencies": {
    "typescript": "^5.5.4",
    "tsx": "^4.16.2",
    "vitest": "^2.0.5",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/uuid": "^9.0.8",
    "@types/node": "^20.14.0",
    "eslint": "^8.57.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "keywords": [],
  "author": "",
  "license": "ISC"
}
